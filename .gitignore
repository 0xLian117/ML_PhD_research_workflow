# ══════════════════════════════════════════════════
# ML PhD Research Workflow — .gitignore
# ══════════════════════════════════════════════════

# ── Code projects (each is its own git repo) ──
# Add your project directories here:
# code/project_a/
# code/project_b/
code/*/

# ── Project-specific context (customize locally) ──
CLAUDE.md
context/

# ── Content directories (framework tracked, content not) ──
results/**
explorations/**
slides/*/

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── Virtual environments ──
.venv/
venv/
env/

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── Secrets ──
.env
.env.*
*.key
*credentials*
*secret*

# ── Generated figures (全部 gitignore, 仅 DESIGN_THEORY.md 进 git) ──
figures/src/
figures/out/

# ── Slides (Slidev, 每次演示一个子目录) ──

# ── ML artifacts (if any leak to root) ──
*.pt
*.pth
*.onnx
*.h5
*.pkl
wandb/

# ── LaTeX build artifacts ──
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.toc
*.nav
*.snm
*.vrb

# ── Reports (local only) ──
reports/**/*.md
reports/**/*.pdf

# ── Claude Code local/session state ──
.claude/settings.local.json
.claude/projects/
.claude/hooks/.response_counter

# ── OS ──
.DS_Store
Thumbs.db
